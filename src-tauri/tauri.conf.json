{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexSpot",
  "version": "0.2.1",
  "identifier": "com.yoyos.nexspot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NexSpot",
        "width": 800,
        "height": 680,
        "minWidth": 600,
        "minHeight": 500,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": null,
    "shell": null,
    "notification": null,
    "single-instance": null,
    "dialog": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}